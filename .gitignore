cat > .gitignore << 'EOF'
# Environment - NEVER push this
.env

# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc

# Jupyter
notebook/
*.ipynb

# OS
.DS_Store
Thumbs.db

# Large model files
*.bin
*.pt
*.pth

# FAISS index (large binary files)
faiss_store/

# Uploaded docs
data/uploaded/
EOF